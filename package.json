{
  "name": "saasaloy-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Saasaloy CLI + module registry — the tool repo",
  "license": "MIT",
  "packageManager": "pnpm@11.14.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "cli": "node packages/cli/dist/index.js",
    "sync": "pnpm --filter saasaloy build && node packages/cli/dist/index.js sync",
    "cli:link": "pnpm --filter saasaloy build && pnpm add --global ./packages/cli",
    "cli:unlink": "pnpm rm --global saasaloy",
    "cli:dev": "pnpm --filter saasaloy dev",
    "play:init": "pnpm --filter saasaloy build && node packages/cli/dist/index.js init .dev/playground --force && pnpm -C .dev/playground install",
    "play:sync": "node packages/cli/dist/index.js init .dev/playground --force",
    "play:dev": "pnpm -C .dev/playground dev",
    "play:watch": "node scripts/watch-template.mjs"
  },
  "devDependencies": {
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  }
}
