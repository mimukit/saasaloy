{
  "name": "saasaloy",
  "version": "0.0.0",
  "description": "Composable SaaS accelerator kit.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "saasaloy": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "schemas/*.schema.json"
  ],
  "engines": {
    "node": ">=24.13.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsup": "8.5.1",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@clack/prompts": "1.7.0",
    "ajv": "8.17.1",
    "diff": "9.0.0",
    "giget": "3.3.0",
    "jsonc-parser": "3.3.1",
    "magicast": "0.5.3",
    "picocolors": "1.1.1"
  }
}
