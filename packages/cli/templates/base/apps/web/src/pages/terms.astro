---
import { siteName } from "@repo/ui";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Terms of Service — {siteName}</title>
    <style>
      body { font-family: system-ui, sans-serif; max-width: 42rem; margin: 4rem auto; padding: 0 1.5rem; line-height: 1.6; }
      a { color: inherit; }
    </style>
  </head>
  <body>
    <main>
      <h1>Terms of Service</h1>
      <p>Placeholder terms for {siteName}. Replace with your own before launch.</p>
      <p><a href="/">← Home</a></p>
    </main>
  </body>
</html>
